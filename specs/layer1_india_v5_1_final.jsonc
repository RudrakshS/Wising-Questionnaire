        // CLASSIFICATION: CONDITIONAL
        // ENABLED IF: acquisition_date < "2018-02-01" AND asset_class IN ["listed_equity","equity_mutual_fund"]
        // Grandfathered FMV per s.112A. Engine uses MAX(purchase_value, qty * fmv_31jan2018) as cost.

        "sale_date": null,
        // CLASSIFICATION: CONDITIONAL
        "sale_value": null,
        // CLASSIFICATION: CONDITIONAL
        "sale_currency": null,
        // CLASSIFICATION: OPTIONAL
        "stt_paid": null
        // CLASSIFICATION: CONDITIONAL
      }
    ]
  },


