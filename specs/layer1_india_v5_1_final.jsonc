      }
    ]
  },


  // ══════════════════════════════════════════════════════════════════════
  // SECTION 11 — SHARE BUYBACK (post-1 Oct 2024 two-leg treatment)
  // Buybacks on/after 1 Oct 2024: full consideration = deemed dividend (slab)
  // AND original cost = capital loss (carry-forward).
  // ══════════════════════════════════════════════════════════════════════

  "share_buyback": {

    "has_buyback_transaction": null,
    // CLASSIFICATION: REQUIRED

    "transactions": [
      {
        "company_name": null,
        // CLASSIFICATION: OPTIONAL
        "isin": null,
        // CLASSIFICATION: OPTIONAL
        "buyback_date": null,                      // "YYYY-MM-DD"
        // CLASSIFICATION: CONDITIONAL
        "tender_or_open_market": null,             // "tender" | "open_market"
        // CLASSIFICATION: CONDITIONAL
        "shares_tendered": null,                   // integer
        // CLASSIFICATION: CONDITIONAL
        "consideration_received_inr": null,        // integer (INR)
        // CLASSIFICATION: CONDITIONAL
        "original_cost_inr": null,                 // integer (INR)
        // CLASSIFICATION: CONDITIONAL
        "original_acquisition_date": null,         // "YYYY-MM-DD"
        // CLASSIFICATION: CONDITIONAL

        "buyback_pre_or_post_oct2024": null,
        // CLASSIFICATION: DERIVED
        // DERIVED | "pre_oct2024" | "post_oct2024"
        // Engine sets based on buyback_date.
        // post_oct2024 → TWO LEGS:
        //   Leg A: full consideration_received_inr → other_sources.dividend_inr (slab)
        //   Leg B: original_cost_inr → capital loss → carry_forward_losses.cg_loss_cf
        // pre_oct2024 → s.115QA company-level tax; nothing taxed in shareholder's hands.

        "deemed_dividend_inr": null,
        // CLASSIFICATION: DERIVED
        // DERIVED | integer (INR)
        // Equals consideration_received_inr if post_oct2024, else 0. Routes to other_sources.

        "capital_loss_inr": null
        // CLASSIFICATION: DERIVED
        // DERIVED | integer (INR)
        // Equals original_cost_inr if post_oct2024, else 0. Routes to carry_forward_losses.
      }
    ]
  },


  // ══════════════════════════════════════════════════════════════════════
  // SECTION 12 — DOMESTIC INCOME HEADS (detailed sub-fields)
  // Income scope: NR → India-source only. RNOR → India + India-controlled business.
  //               ROR → worldwide.
  // ══════════════════════════════════════════════════════════════════════

  "domestic_income": {

    // ── SALARY (DOM-01) ──────────────────────────────────────────────
    "salary": {
      "has_salary_income": null,                // bool — gate
      // CLASSIFICATION: REQUIRED
      "gross_salary_inr": null,                 // integer (INR)
      // CLASSIFICATION: CONDITIONAL
